// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URL is now passed directly to PrismaClient constructor
  // For Prisma Accelerate, use accelerateUrl in PrismaClient
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  family
  restaurant
  shop
  ngo
  admin
}

enum ShoppingListPriority {
  low
  medium
  high
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
}

enum UploadAssociatedType {
  inventory
  log
  profile
}

enum StorageType {
  fresh
  chilled
  frozen
  dry
  ambient
}

enum RestaurantStorageType {
  fresh
  chilled
  frozen
  dry
}

enum ShopStorageType {
  frozen
  chilled
  ambient
}

enum Status {
  available
  pending
  claimed
  expired
  completed
  delivered
  cancelled
  declined
  approved
  scheduled
  enRoute
  pickedUp
  partial
  redirected
  acknowledged
  resolved
  picked
  inProgress
  upcoming
  active
  none
}

enum CookingFrequency {
  daily
  fewTimesWeek
  weekly
  occasional
}

enum DietaryType {
  vegan
  vegetarian
  halal
  keto
  lowSodium
  general
}

enum PriceSensitivity {
  low
  medium
  high
}

enum MealPrepPreference {
  quick
  diverse
  budget
  highProtein
}

enum WasteSensitivityLevel {
  low
  medium
  high
}

enum SustainabilityPreference {
  minimal
  moderate
  high
}

enum LeftoverComfortLevel {
  low
  medium
  high
}

enum CommunityRole {
  member
  champion
  organizer
}

enum Visibility {
  public
  community
  private
}

enum NotificationType {
  claim
  volunteer
  announcement
  surplus
  reminder
  urgentOffer
  pickup
  feedback
  message
}

enum Severity {
  info
  warning
  critical
}

enum DonorType {
  building
  restaurant
  household
  kitchen
  communityKitchen
  ngo
}

enum UrgencyLevel {
  low
  medium
  high
}

enum VehicleType {
  van
  bike
  car
  onFoot
}

enum PriceMapMethod {
  percentage
  fixed
}

enum DonationRecipientType {
  ngo
  communityKitchen
}

enum CommunityLeaderboardType {
  topSharers
  zeroWaste
  volunteerStars
  buildingImpact
  weeklyXp
}

enum RestaurantItemStatus {
  normal
  expiring
  overstocked
}

enum WasteScore {
  low
  medium
  high
}

enum Condition {
  fresh
  nearExpiry
}

enum TaskCategory {
  expiry
  pricing
  surplus
  cleaning
}

enum TaskPriority {
  low
  medium
  high
}

// ============================================================================
// CORE TABLES
// ============================================================================

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  name         String   @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.Text
  householdId  String?  @map("household_id") @db.Uuid
  role         UserRole @default(family)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  inventoryItems            InventoryItem[]
  consumptionLogs           ConsumptionLog[]
  shoppingListItems         ShoppingListItem[]
  mealPlans                 MealPlan[]
  uploads                   Upload[]
  badges                    Badge[]
  userXp                    UserXp?
  nutritionData             NutritionData[]
  communitySurplusPosts     CommunitySurplusPost[]
  surplusRequests           SurplusRequest[]
  surplusComments           SurplusComment[]
  leftoverItems             LeftoverItem[]
  leftoverItemClaims        LeftoverItemClaim[]
  communityNotifications    CommunityNotification[]
  communityProfile          CommunityProfile?
  restaurantInventoryItems  RestaurantInventoryItem[]
  restaurantMenuItems       RestaurantMenuItem[]
  restaurantSurplusItems    RestaurantSurplusItem[]
  restaurantDonationLogs    RestaurantDonationLog[]
  restaurantImpactMetrics   RestaurantImpactMetric?
  restaurantStaffTasks      RestaurantStaffTask[]
  restaurantShiftSchedule   RestaurantShiftSchedule[]
  restaurantPreferences     RestaurantPreferences?
  ngoCapacitySettings       NgoCapacitySetting?
  ngoDonationOffers         NgoDonationOffer[] @relation("NgoDonationOffers")
  ngoDonationOffersDonor    NgoDonationOffer[] @relation("NgoDonationOffersDonor")
  ngoPickupSchedules        NgoPickupSchedule[]
  ngoDonationHistory        NgoDonationHistory[]
  ngoPartnerProfiles        NgoPartnerProfile[]
  ngoFeedbackEntries        NgoFeedbackEntry[]
  ngoImpactStories          NgoImpactStory[]
  ngoNotifications          NgoNotification[]
  shopInventoryItems        ShopInventoryItem[]
  shopPriceMapEntries       ShopPriceMapEntry[]
  shopDiscountSuggestions   ShopDiscountSuggestion[]
  shopSurplusItems          ShopSurplusItem[]
  shopAnalyticsRecords      ShopAnalyticsRecord?
  shopStaffMembers          ShopStaffMember[]
  shopStaffTasks            ShopStaffTask[]
  shopShifts                ShopShift[]
  shopProfile               ShopProfile?

  @@index([email])
  @@index([householdId])
  @@index([role])
  @@map("users")
}

model FoodItem {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(255)
  category        String   @db.VarChar(100)
  typicalExpiryDays Int    @map("typical_expiry_days")
  storageTips     String?  @map("storage_tips") @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  inventoryItems  InventoryItem[]

  @@map("food_items")
}

model InventoryItem {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  name        String    @db.VarChar(255)
  quantity    Decimal   @db.Decimal(10, 2)
  unit        String?   @db.VarChar(50)
  expiryDate  DateTime? @map("expiry_date") @db.Timestamptz(6)
  category    String?   @db.VarChar(100)
  location    String?   @db.VarChar(100)
  foodItemId  String?   @map("food_item_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodItem  FoodItem? @relation(fields: [foodItemId], references: [id], onDelete: SetNull)
  consumptionLogs ConsumptionLog[]

  @@index([userId])
  @@index([expiryDate])
  @@index([category])
  @@index([foodItemId])
  @@map("inventory_items")
}

model ConsumptionLog {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  inventoryItemId String?  @map("inventory_item_id") @db.Uuid
  foodName        String   @map("food_name") @db.VarChar(255)
  quantity        Decimal  @db.Decimal(10, 2)
  unit            String?  @db.VarChar(50)
  category        String?  @db.VarChar(100)
  consumedAt      DateTime @map("consumed_at") @db.Timestamptz(6)
  wasWasted       Boolean  @default(false) @map("was_wasted")
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem?  @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([consumedAt])
  @@index([inventoryItemId])
  @@map("consumption_logs")
}

model ShoppingListItem {
  id            String            @id @default(uuid()) @db.Uuid
  userId        String            @map("user_id") @db.Uuid
  householdId   String?           @map("household_id") @db.Uuid
  name          String            @db.VarChar(255)
  quantity      Decimal           @db.Decimal(10, 2)
  unit          String?           @db.VarChar(50)
  category      String?           @db.VarChar(100)
  priority      ShoppingListPriority @default(medium)
  purchased     Boolean           @default(false)
  purchasedAt   DateTime?         @map("purchased_at") @db.Timestamptz(6)
  estimatedPrice Decimal?         @map("estimated_price") @db.Decimal(10, 2)
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([householdId])
  @@index([purchased])
  @@map("shopping_list_items")
}

model MealPlan {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  householdId String?  @map("household_id") @db.Uuid
  date        DateTime @db.Date
  mealType    MealType @map("meal_type")
  name        String   @db.VarChar(255)
  description String?  @db.Text
  ingredients String[] @db.Text
  servings    Int?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([householdId])
  @@map("meal_plans")
}

model Resource {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(255)
  description String?  @db.Text
  category    String   @db.VarChar(100)
  url         String?  @db.Text
  tags        String[] @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("resources")
}

model Upload {
  id             String              @id @default(uuid()) @db.Uuid
  userId         String              @map("user_id") @db.Uuid
  fileName       String              @map("file_name") @db.VarChar(255)
  fileType       String              @map("file_type") @db.VarChar(100)
  fileSize       BigInt              @map("file_size")
  data           String?             @db.Text
  associatedType UploadAssociatedType? @map("associated_type")
  associatedId   String?             @map("associated_id") @db.Uuid
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("uploads")
}

// ============================================================================
// GAMIFICATION & USER PROGRESS
// ============================================================================

model Badge {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  badgeId     String   @map("badge_id") @db.VarChar(100)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  icon        String?  @db.VarChar(255)
  unlockedAt  DateTime @map("unlocked_at") @db.Timestamptz(6)
  xpReward    Int      @default(0) @map("xp_reward")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
  @@map("badges")
}

model UserXp {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  totalXp        Int      @default(0) @map("total_xp")
  level          Int      @default(1)
  currentLevelXp Int      @default(0) @map("current_level_xp")
  nextLevelXp    Int      @default(100) @map("next_level_xp")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_xp")
}

// ============================================================================
// FAMILY & PREFERENCES
// ============================================================================

model FamilyPreferences {
  id                      String                  @id @default(uuid()) @db.Uuid
  householdId             String                  @unique @map("household_id") @db.Uuid
  householdSize           Int                     @map("household_size")
  ageGroups               Json?                   @map("age_groups")
  cookingFrequency        CookingFrequency?       @map("cooking_frequency")
  eatingSchedule          Json?                   @map("eating_schedule")
  dietaryType             DietaryType?            @map("dietary_type")
  dietaryRestrictions     String[]                @map("dietary_restrictions") @db.Text
  allergies               String[]                @db.Text
  healthConditions        String[]                @map("health_conditions") @db.Text
  weeklyBudget            Decimal?                @map("weekly_budget") @db.Decimal(10, 2)
  budgetRange             Json?                   @map("budget_range")
  preferredStores         String[]                @map("preferred_stores") @db.Text
  priceSensitivity        PriceSensitivity?       @map("price_sensitivity")
  preferredCuisines       String[]                @map("preferred_cuisines") @db.Text
  mealPrepPreference      MealPrepPreference?     @map("meal_prep_preference")
  wasteSensitivityLevel   WasteSensitivityLevel?  @map("waste_sensitivity_level")
  sustainabilityPreference SustainabilityPreference? @map("sustainability_preference")
  leftoverComfortLevel    LeftoverComfortLevel?   @map("leftover_comfort_level")
  dailyCalories           Int?                    @map("daily_calories")
  macroGoal               Json?                   @map("macro_goal")
  vitaminsFocus           String[]                @map("vitamins_focus") @db.Text
  avoidExcess             String[]                @map("avoid_excess") @db.Text
  createdAt               DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("family_preferences")
}

model NutritionData {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  date          DateTime @db.Date
  calories      Decimal  @default(0) @db.Decimal(10, 2)
  protein       Decimal  @default(0) @db.Decimal(10, 2)
  carbs         Decimal  @default(0) @db.Decimal(10, 2)
  fats          Decimal  @default(0) @db.Decimal(10, 2)
  fiber         Decimal  @default(0) @db.Decimal(10, 2)
  sugar         Decimal  @default(0) @db.Decimal(10, 2)
  sodium        Decimal  @default(0) @db.Decimal(10, 2)
  vitaminA      Decimal  @default(0) @map("vitamin_a") @db.Decimal(10, 2)
  vitaminB      Decimal  @default(0) @map("vitamin_b") @db.Decimal(10, 2)
  vitaminC      Decimal  @default(0) @map("vitamin_c") @db.Decimal(10, 2)
  vitaminD      Decimal  @default(0) @map("vitamin_d") @db.Decimal(10, 2)
  iron          Decimal  @default(0) @db.Decimal(10, 2)
  calcium       Decimal  @default(0) @db.Decimal(10, 2)
  nutritionScore Int?    @map("nutrition_score")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("nutrition_data")
}

model PriceComparison {
  id        String   @id @default(uuid()) @db.Uuid
  itemName  String   @map("item_name") @db.VarChar(255)
  category  String?  @db.VarChar(100)
  stores    Json     @db.JsonB
  bestPrice Json     @map("best_price") @db.JsonB
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("price_comparisons")
}

// ============================================================================
// COMMUNITY FEATURES
// ============================================================================

model CommunitySurplusPost {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  userName      String    @map("user_name") @db.VarChar(255)
  avatarUrl     String?   @map("avatar_url") @db.Text
  title         String    @db.VarChar(255)
  description   String    @db.Text
  category      String    @db.VarChar(100)
  tags          String[]  @db.Text
  quantity      Decimal   @db.Decimal(10, 2)
  unit          String    @db.VarChar(50)
  pickupWindow  Json      @map("pickup_window") @db.JsonB
  pickupLocation String   @map("pickup_location") @db.Text
  distanceKm    Decimal?  @map("distance_km") @db.Decimal(10, 2)
  image         String?   @db.Text
  status        Status    @default(available)
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  requests  SurplusRequest[]
  comments  SurplusComment[]

  @@index([userId])
  @@index([status])
  @@map("community_surplus_posts")
}

model SurplusRequest {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  userName  String   @map("user_name") @db.VarChar(255)
  message   String?  @db.Text
  status    Status   @default(pending)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  post  CommunitySurplusPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  user  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("surplus_requests")
}

model SurplusComment {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  userName  String   @map("user_name") @db.VarChar(255)
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  post  CommunitySurplusPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  user  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("surplus_comments")
}

model LeftoverItem {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  userName      String   @map("user_name") @db.VarChar(255)
  avatarUrl     String?  @map("avatar_url") @db.Text
  dishName      String   @map("dish_name") @db.VarChar(255)
  description   String   @db.Text
  portions      Int
  distanceKm    Decimal  @map("distance_km") @db.Decimal(10, 2)
  dietaryTags   String[] @map("dietary_tags") @db.Text
  allergens     String[] @db.Text
  pickupWindow  String   @map("pickup_window") @db.Text
  status        Status   @default(available)
  image         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  claims  LeftoverItemClaim[]

  @@index([userId])
  @@index([status])
  @@map("leftover_items")
}

model LeftoverItemClaim {
  id            String   @id @default(uuid()) @db.Uuid
  leftoverItemId String  @map("leftover_item_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  userName      String   @map("user_name") @db.VarChar(255)
  message       String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  leftoverItem  LeftoverItem  @relation(fields: [leftoverItemId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("leftover_item_claims")
}

model CommunityKitchenEvent {
  id            String   @id @default(uuid()) @db.Uuid
  title         String   @db.VarChar(255)
  description   String   @db.Text
  date          DateTime @db.Date
  time          String   @db.VarChar(20)
  location      String   @db.Text
  tags          String[] @db.Text
  volunteersNeeded Int   @default(0) @map("volunteers_needed")
  volunteers    Json?    @db.JsonB
  foodSavedKg   Decimal  @default(0) @map("food_saved_kg") @db.Decimal(10, 2)
  status        Status   @default(upcoming)
  image         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([date])
  @@map("community_kitchen_events")
}

model CommunityLeaderboard {
  id        String   @id @default(uuid()) @db.Uuid
  type      String   @db.VarChar(50)
  entries   Json     @db.JsonB
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("community_leaderboard")
}

model CommunityImpact {
  id                  String   @id @default(uuid()) @db.Uuid
  totalSurplusKg      Decimal  @default(0) @map("total_surplus_kg") @db.Decimal(10, 2)
  donations           Int      @default(0)
  co2PreventedKg      Decimal  @default(0) @map("co2_prevented_kg") @db.Decimal(10, 2)
  waterSavedLiters    Decimal  @default(0) @map("water_saved_liters") @db.Decimal(10, 2)
  mealsProvided       Int      @default(0) @map("meals_provided")
  weeklyTrend         Json?    @map("weekly_trend") @db.JsonB
  personalContribution Json?   @map("personal_contribution") @db.JsonB
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("community_impact")
}

model CommunityNotification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  title     String           @db.VarChar(255)
  message   String           @db.Text
  type      String           @db.VarChar(50)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@map("community_notifications")
}

model CommunityProfile {
  id                    String      @id @default(uuid()) @db.Uuid
  userId                String      @unique @map("user_id") @db.Uuid
  username              String      @unique @db.VarChar(255)
  avatarUrl             String?     @map("avatar_url") @db.Text
  communityRole         String      @default("member") @map("community_role") @db.VarChar(50)
  bio                   String?     @db.Text
  preferredItems        String[]    @map("preferred_items") @db.Text
  avoidItems            String[]    @map("avoid_items") @db.Text
  dietaryRestrictions   String[]    @map("dietary_restrictions") @db.Text
  allergens             String[]    @db.Text
  acceptsHotMeals       Boolean     @default(false) @map("accepts_hot_meals")
  distancePreference    String?     @map("distance_preference") @db.VarChar(10)
  visibility            String      @default("public") @db.VarChar(20)
