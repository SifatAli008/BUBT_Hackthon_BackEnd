  avatar        String?  @db.Text
  responsibilities String[] @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks  ShopStaffTask[]
  shifts ShopShift[]

  @@map("shop_staff_members")
}

model ShopStaffTask {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  title       String       @db.VarChar(255)
  description String?      @db.Text
  assigneeId  String?      @map("assignee_id") @db.Uuid
  due         DateTime     @db.Timestamptz(6)
  completed   Boolean      @default(false)
  category    TaskCategory?
  priority    TaskPriority @default(medium)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignee ShopStaffMember? @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@map("shop_staff_tasks")
}

model ShopShift {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  staffId   String   @map("staff_id") @db.Uuid
  day       String   @db.VarChar(20)
  startTime String   @map("start_time") @db.VarChar(20)
  endTime   String   @map("end_time") @db.VarChar(20)
  station   String   @db.VarChar(100)
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  staff ShopStaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("shop_shifts")
}

model ShopProfile {
  id                      String   @id @default(uuid()) @db.Uuid
  userId                  String   @unique @map("user_id") @db.Uuid
  storeName               String   @map("store_name") @db.VarChar(255)
  address                 String   @db.Text
  contactNumber           String   @map("contact_number") @db.VarChar(50)
  managerName             String   @map("manager_name") @db.VarChar(255)
  operatingHours          String   @map("operating_hours") @db.Text
  notificationPreferences Json?    @map("notification_preferences") @db.JsonB
  donationPreferences     String[] @map("donation_preferences") @db.Text
  categoryPriority        String[] @map("category_priority") @db.Text
  barcodePrefix           String?  @map("barcode_prefix") @db.VarChar(50)
  updatedAt               DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("shop_profiles")
}
